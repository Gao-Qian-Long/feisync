# Node.js 依赖
node_modules/

# TypeScript 编译输出
*.js.map

# 保留必要的 JS 文件（esbuild 配置和插件入口）
!esbuild.config.js
!main.js

# 包锁文件
package-lock.json

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 操作系统文件
.DS_Store
Thumbs.db

# Obsidian 插件相关
.obsidian/

# 日志文件
*.log
npm-debug.log*
.roo/
.codebuddy/

# 开发计划文档（不需要上传）
plans/
# 临时文件
*.tmp
*.temp

# 本地配置文件（包含敏感凭证）
data.json
error.txt